# Railway PostgreSQL 연결 문자열
# 로컬 개발: Railway 대시보드 > Postgres 서비스 > Variables 의 DATABASE_PUBLIC_URL 값 사용
# Railway 배포: 내부 DATABASE_URL(postgres.railway.internal)을 환경변수로 주입
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# 관리자 인증 (2차 관리자 대시보드에서 사용)
# ADMIN_USERNAME="YOUR_ADMIN_ID_HERE"
# ADMIN_PASSWORD="YOUR_ADMIN_PASSWORD_HERE"
